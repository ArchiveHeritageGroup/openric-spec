#
# OpenRiC SHACL shapes — profile: authority-context
# =================================================
# Shapes for the contextual entities that qualify records: Places, Rules,
# and Activities (Production / Accumulation).
#
# Shapes in this file:
#   - ProductionShape       — rico:Production (creation event)
#   - AccumulationShape     — rico:Accumulation (aggregation event)
#   - ActivityShape         — rico:Activity (generic)
#   - PlaceShape            — rico:Place
#   - PlaceNameShape        — structured rico:hasPlaceName values
#   - RuleShape             — rico:Rule (mandates, legislation, policies)
#
# Usage:
#   pyshacl -s always-on.shacl.ttl -s authority-context.shacl.ttl \
#           -d data.jsonld -f human

@prefix sh:   <http://www.w3.org/ns/shacl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix rico: <https://www.ica.org/standards/RiC/ontology#> .
@prefix :     <https://openric.org/shapes#> .


# ----------------------------------------------------------------------------
# Activity shapes
# ----------------------------------------------------------------------------

:ProductionShape a sh:NodeShape ;
    sh:targetClass rico:Production ;
    sh:name "Production Activity Validation" ;

    # rico:resultsOrResultedIn is recommended but not required at v0.1 —
    # many implementations emit the back-link from the Record instead, or
    # leave cross-entity links to full-graph validation (see
    # profile: graph-traversal).
    sh:property [
        sh:path rico:resultsOrResultedIn ;
        sh:severity sh:Warning ;
        sh:message "Production should result in at least one record"
    ] ;

    sh:property [
        sh:path rico:hasOrHadParticipant ;
        sh:severity sh:Warning ;
        sh:message "Production should have at least one participant (creator)"
    ] ;

    sh:property [
        sh:path rico:isOrWasAssociatedWithDate ;
        sh:severity sh:Warning ;
        sh:message "Production should have an associated date"
    ] .


:AccumulationShape a sh:NodeShape ;
    sh:targetClass rico:Accumulation ;
    sh:name "Accumulation Activity Validation" ;

    sh:property [
        sh:path rico:resultsOrResultedIn ;
        sh:severity sh:Warning ;
        sh:message "Accumulation should result in at least one record"
    ] .


:ActivityShape a sh:NodeShape ;
    sh:targetClass rico:Activity ;
    sh:name "General Activity Validation" ;

    sh:property [
        sh:path rico:hasActivityType ;
        sh:maxCount 1 ;
        sh:severity sh:Info ;
        sh:message "Activity should have an activity type"
    ] .


# ----------------------------------------------------------------------------
# Place shapes
# ----------------------------------------------------------------------------

:PlaceShape a sh:NodeShape ;
    sh:targetClass rico:Place ;
    sh:name "Place Validation" ;

    # Accept either rico:name (shorthand) OR rico:hasPlaceName (canonical).
    sh:or (
        [ sh:property [ sh:path rico:name ; sh:minCount 1 ] ]
        [ sh:property [ sh:path rico:hasPlaceName ; sh:minCount 1 ] ]
    ) ;

    sh:property [
        sh:path rico:hasPlaceName ;
        sh:node :PlaceNameShape ;
        sh:severity sh:Info ;
        sh:message "When present, rico:hasPlaceName must be properly structured"
    ] .


:PlaceNameShape a sh:NodeShape ;
    sh:property [
        sh:path rico:textualValue ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:minLength 1 ;
        sh:message "PlaceName must have a textual value"
    ] .


# ----------------------------------------------------------------------------
# Rule shape
# ----------------------------------------------------------------------------

:RuleShape a sh:NodeShape ;
    sh:targetClass rico:Rule ;
    sh:name "Rule (Mandate / Legislation / Policy) Validation" ;

    sh:property [
        sh:path rico:title ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:minLength 1 ;
        sh:message "Rule must have a title"
    ] ;

    sh:property [
        sh:path rico:ruleType ;
        sh:severity sh:Warning ;
        sh:message "Rule should have a rule type"
    ] ;

    sh:property [
        sh:path rico:jurisdiction ;
        sh:severity sh:Info ;
        sh:message "Rule should specify the jurisdiction it applies to"
    ] ;

    sh:or (
        [ sh:property [ sh:path rico:descriptiveNote ; sh:minCount 1 ] ]
        [ sh:property [ sh:path rico:ruleType ; sh:minCount 1 ] ]
    ) .
